# All optional — the app runs fully local with none of these set.

# --- Optional cloud sync (see SUPABASE_SETUP.md) ---------------------------
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJ...

# --- Optional zero-click free AI assist ------------------------------------
# Baked into the bundle at build time (never committed). Enables the OpenRouter
# free vision tier for anonymous users.
# OPENROUTER_API_KEY=sk-or-...

# --- OCR engine tier --------------------------------------------------------
# Default is Tesseract (vendored from npm, fully offline). Opt into the
# stronger on-device PaddleOCR tier after `npm i onnxruntime-web && npm run vendor:paddle`:
# VITE_OCR_ENGINE=paddle

# Serve Tesseract language data from the public CDN instead of vendoring:
# VITE_TESSDATA_LOCAL=0

# --- Perspective correction (angled phone photos) ---------------------------
# Requires a vendored OpenCV.js at public/vendor/opencv/opencv.js.
# VITE_PERSPECTIVE=1
